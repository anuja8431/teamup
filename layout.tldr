							},
							"content": [
								{
									"type": "text",
									"text": "Core Features User Login/Signup: Simple registration using email and password User Profile: Name, Skills (e.g., HTML, Java, UI/UX), Interests. Post Creation: 'Looking for Team Members' or 'Looking to Join a Team' . Browse & Search: View users and posts, filter results based on skills. Team Request System: Send requests to join a team, accept or reject requests. Basic Dashboard: View created posts, manage incoming and outgoing requests."
								}
							]
						}
					]
				}
